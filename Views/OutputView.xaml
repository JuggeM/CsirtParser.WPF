<UserControl x:Class="CsirtParser.WPF.Views.OutputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CsirtParser.WPF.Views">
    <StackPanel>
        <TextBlock Text="Output" Style="{StaticResource SectionTitle}"/>

        <!-- Output directory -->
        <TextBlock Text="Output directory" Style="{StaticResource FieldLabel}"/>
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding Config.OutputPath, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,8,0"/>
            <Button Grid.Column="1"
                    Content="Browse…"
                    Style="{StaticResource StandardButton}"
                    Command="{Binding BrowseOutputCommand}"/>
        </Grid>

        <Separator/>

        <!-- Output toggles -->
        <CheckBox Content="Write normalized CSV (normalized.csv)"
                  IsChecked="{Binding Config.OutputNormalizedCsv}"/>
        <CheckBox Content="Generate QuickWins.txt"
                  IsChecked="{Binding Config.OutputQuickWins}"/>
        <CheckBox Content="Write per-log summary files"
                  IsChecked="{Binding Config.OutputPerLogSummaries}"/>
        <CheckBox Content="Append timeline header to QuickWins"
                  IsChecked="{Binding Config.OutputTimeline}"/>
        <CheckBox Content="Collapse duplicates (cron, syslog, messages)"
                  IsChecked="{Binding Config.OutputCollapseDups}"
                  Margin="0,0,0,20"/>

        <Separator/>

        <!-- Run bar -->
        <Grid Margin="0,8,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="▶  Run parser"
                    Style="{StaticResource PrimaryButton}"
                    Width="130"
                    Command="{Binding RunCommand}"
                    IsEnabled="{Binding CanRun}"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding RunStatusText}"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"
                       Margin="12,0,0,0"/>
        </Grid>

        <!-- Live log output -->
        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8">
            <ScrollViewer x:Name="LogScroll"
                          MaxHeight="280"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding LogEntries}"
                              x:Name="LogList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Margin="0,1"
                                       Foreground="{Binding Level,
                                           Converter={StaticResource LogLevelToBrushConverter}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </StackPanel>
</UserControl>
